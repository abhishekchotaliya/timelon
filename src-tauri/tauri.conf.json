{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Timelon",
  "version": "0.1.0",
  "identifier": "com.timelon.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "title": "Timelon",
        "width": 780,
        "height": 580,
        "minWidth": 680,
        "minHeight": 480,
        "center": true,
        "visible": true,
        "transparent": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
